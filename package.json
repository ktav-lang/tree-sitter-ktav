{
  "name": "tree-sitter-ktav",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for Ktav (כְּתָב) — the Written Configuration Format",
  "keywords": [
    "parser",
    "lexer",
    "tree-sitter",
    "ktav",
    "config",
    "configuration"
  ],
  "author": "Marat K <phpcraftdream@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/ktav-lang/tree-sitter-ktav",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ktav-lang/tree-sitter-ktav.git"
  },
  "bugs": {
    "url": "https://github.com/ktav-lang/tree-sitter-ktav/issues"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "files": [
    "grammar.js",
    "binding.gyp",
    "bindings/node/*",
    "queries/*",
    "src/**"
  ],
  "dependencies": {
    "node-addon-api": "^7.1.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.26.0",
    "prebuildify": "^6.0.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.21.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js"
  },
  "tree-sitter": [
    {
      "scope": "source.ktav",
      "file-types": [
        "ktav"
      ],
      "injection-regex": "^ktav$",
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm",
      "injections": "queries/injections.scm"
    }
  ]
}
